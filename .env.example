# Backend / services
DATABASE_URL=sqlite+aiosqlite:///./results.db
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=defect-images
MINIO_USE_SSL=false

# Models (paths relative to backend cwd or set absolute)
PATCHCORE_MODEL_PATH=../models/patchcore_bottle.pkl
YOLO_MODEL_PATH=../mlflow/yolov8/defect_nano/weights/best.pt
ACTIVE_MODEL_MANIFEST_PATH=../models/active_model.json
MODEL_MODE=auto
ALLOW_DEMO_INFERENCE_WITHOUT_MODEL=true

# API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
INFERENCE_LOG_LEVEL=INFO
