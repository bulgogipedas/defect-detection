# Backend / services
# Supabase Postgres URL (async SQLAlchemy), example:
# postgresql+asyncpg://postgres:<db_password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=
DB_PROVIDER=supabase-postgres
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=defect-images
MINIO_USE_SSL=false

# Models (paths relative to backend cwd or set absolute)
PATCHCORE_MODEL_PATH=../models/patchcore_bottle.pkl
YOLO_MODEL_PATH=../mlflow/yolov8/defect_nano/weights/best.pt
ACTIVE_MODEL_MANIFEST_PATH=../models/active_model.json
MODEL_MODE=auto
ALLOW_DEMO_INFERENCE_WITHOUT_MODEL=true
DATA_RAW_ROOT=~/Downloads/mvtec_anomaly_detection

# API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
INFERENCE_LOG_LEVEL=INFO
